# === Synapse Configuration ===
# API 키는 절대 코드에 하드코딩하지 말 것

# Brave Search API (무료: 월 1,000회)
# 발급: https://api-dashboard.search.brave.com/
BRAVE_API_KEY=

# Serper.dev (무료: 월 2,500회, 구글 검색 결과)
# 발급: https://serper.dev
SERPER_API_KEY=

# Tavily (무료: 월 1,000회, AI 최적화)
# 발급: https://app.tavily.com
TAVILY_API_KEY=

# Daum (Kakao) 검색 API (무료: 월 3,000,000회)
# 발급: https://developers.kakao.com/
DAUM_API_KEY=

# Naver Search API (무료: 일 25,000회 — 한국어 검색)
# 발급: https://developers.naver.com → 앱 등록 → 검색 API 선택
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Exa Search API (무료: 월 1,000회 — AI 에이전트용)
# 발급: https://exa.ai → Dashboard → API Keys
EXA_API_KEY=

# === Server Settings ===
SYNAPSE_HOST=127.0.0.1
SYNAPSE_PORT=8888
SYNAPSE_MAX_RESULTS=20
SYNAPSE_ENGINE_TIMEOUT_SECONDS=4
SYNAPSE_SEARCH_HARD_TIMEOUT_SECONDS=6

# === Engine Selection ===
# 쉼표로 구분, 순서는 우선순위
# 예: brave,serper,tavily,daum,naver,exa
SYNAPSE_ENGINES=brave,serper,tavily,daum,naver,exa

# === Logging ===
SYNAPSE_LOG_LEVEL=INFO
